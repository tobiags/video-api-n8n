# ═══════════════════════════════════════════════════════════════
# VideoGen API — Variables d'environnement
# Copier ce fichier en .env et remplir toutes les valeurs
# NE PAS committer .env dans git !
# ═══════════════════════════════════════════════════════════════

# ─── App ────────────────────────────────────────────────────────
APP_NAME=VideoGen API
APP_VERSION=1.0.0
ENVIRONMENT=development      # development | staging | production
DEBUG=false
HOST=0.0.0.0
PORT=8000
WORKERS=1                    # Garder à 1 jusqu'au Jour 2 (Redis)

# ─── Sécurité ───────────────────────────────────────────────────
# Secret partagé entre n8n et FastAPI
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=CHANGE_ME_generate_with_secrets_token_hex_32

# ─── Claude / Anthropic ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-opus-4-6
CLAUDE_MAX_TOKENS=4096
CLAUDE_MAX_RETRIES=3

# ─── ElevenLabs ─────────────────────────────────────────────────
ELEVENLABS_API_KEY=...
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_DEFAULT_VOICE_ID=CLONE_VOCAL_ID_ICI   # ID du clone vocal Théo
ELEVENLABS_MAX_RETRIES=2
ELEVENLABS_BACKOFF_BASE=5.0

# ─── Kling AI ───────────────────────────────────────────────────
KLING_ACCESS_KEY=...
KLING_SECRET_KEY=...
KLING_BASE_URL=https://api.klingai.com
KLING_MODEL=kling-v1-6
KLING_DURATION=5             # Durée par clip en secondes
KLING_MAX_PARALLEL_JOBS=5    # Limite API officielle
KLING_POLLING_INTERVAL=30.0  # Secondes entre checks statut
KLING_CLIP_TIMEOUT=600       # 10 min max par clip
KLING_MAX_RETRIES=3

# ─── Pexels ─────────────────────────────────────────────────────
PEXELS_API_KEY=...

# ─── Creatomate ─────────────────────────────────────────────────
CREATOMATE_API_KEY=...
CREATOMATE_TEMPLATE_VERTICAL=TEMPLATE_ID_9_16     # À créer dans Creatomate dashboard
CREATOMATE_TEMPLATE_HORIZONTAL=TEMPLATE_ID_16_9   # À créer dans Creatomate dashboard
CREATOMATE_POLLING_INTERVAL=15.0
CREATOMATE_RENDER_TIMEOUT=900
CREATOMATE_MAX_RETRIES=2

# ─── Google ─────────────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_PATH=/opt/videogen/service_account.json
GOOGLE_DRIVE_FOLDER_ID=...   # ID du dossier Drive de destination
GOOGLE_SHEETS_ID=...         # ID du Google Sheets de campagnes
GOOGLE_SHEETS_TAB=Campagnes

# ─── Stratégie B — Bibliothèque clips ───────────────────────────
LIBRARY_PATH=/opt/videogen/library/clips
LIBRARY_INDEX_FILE=/opt/videogen/library/index.json
LIBRARY_SCORE_THRESHOLD=0.7
LIBRARY_CLEANUP_DAYS=90

# ─── HTTP Client ────────────────────────────────────────────────
HTTP_TIMEOUT_DEFAULT=30.0
HTTP_TIMEOUT_VIDEO_GEN=600.0
HTTP_MAX_CONNECTIONS=20
HTTP_MAX_KEEPALIVE=10

# ─── Notifications ──────────────────────────────────────────────
# URL webhook n8n pour les callbacks (succès, erreur, alerte crédits)
N8N_WEBHOOK_NOTIFICATION_URL=http://localhost:5678/webhook/videogen-callback
API_CREDIT_ALERT_THRESHOLD=0.20

# ─── Logo ───────────────────────────────────────────────────────
LOGO_URL=https://ton-cdn.com/logo.png
